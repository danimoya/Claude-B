# Claude-B configuration
# Copy to .env (or ~/.claude-b/.env) and fill in what you need.
# Precedence: process env > ~/.claude-b/.env > ./.env

# --- Required for Claude Code ---
ANTHROPIC_API_KEY=

# --- Optional: Telegram integration ---
# Create a bot via @BotFather on Telegram to get a token.
# `cb init` does this interactively.
TELEGRAM_BOT_TOKEN=
TELEGRAM_ALLOWED_CHAT_IDS=

# --- Optional: voice pipeline ---
# OpenAI key enables both Whisper STT and TTS playback.
OPENAI_API_KEY=
# Or use an alternative STT provider:
# SPEECHMATICS_API_KEY=
# DEEPGRAM_API_KEY=

# --- Optional: Claude-B infrastructure ---
# CB_DATA_DIR=~/.claude-b
# CB_REST_HOST=127.0.0.1
# CB_REST_PORT=3847
# CB_REST_API_KEY=
